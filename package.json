{
  "name": "ticket-flow",
  "version": "0.0.1",
  "private": true,
  "description": "マルチテナント SaaS 向けチケット管理システム",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "oxlint .",
    "format:check": "oxfmt . --check",
    "format": "oxfmt . --write",
    "commitlint": "git log -1 --pretty=%B | pnpm exec commitlint",
    "prepare": "node -e \"const fs=require('fs'); if(process.env.CI || !fs.existsSync('.git')){console.log('Skipping lefthook install');process.exit(0)} require('child_process').execSync('lefthook install', {stdio:'inherit'})\"",
    "migrate": "node scripts/migrate.js up",
    "migrate:rollback": "node scripts/migrate.js down",
    "migrate:create": "node-pg-migrate create --config-file node-pg-migrate.config.json"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.4",
    "lefthook": "^2.1.9",
    "node-pg-migrate": "^8.0.4",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.8.1"
}
