{
  "name": "ticket-flow",
  "version": "0.0.1",
  "private": true,
  "description": "マルチテナント SaaS 向けチケット管理システム",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @ticket-flow/web dev",
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @ticket-flow/shared build",
    "preview": "pnpm --filter @ticket-flow/web preview",
    "test": "pnpm run build:shared && pnpm -r run test && vitest run",
    "test:scripts": "vitest run scripts",
    "test:watch": "pnpm -r run test:watch",
    "test:coverage": "pnpm -r run --if-present test:coverage",
    "typecheck": "pnpm run build:shared && pnpm -r run typecheck",
    "lint": "oxlint .",
    "format:check": "oxfmt . --check --ignore-path .oxfmtignore --ignore-path apps/web/.oxfmtignore",
    "format": "oxfmt . --write --ignore-path .oxfmtignore --ignore-path apps/web/.oxfmtignore",
    "create-issue": "node scripts/create-issue.js",
    "commitlint": "git log -1 --pretty=%B | pnpm exec commitlint",
    "setup": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^4.1.9",
    "lefthook": "^2.1.9",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
