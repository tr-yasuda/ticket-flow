{
  "name": "@ticket-flow/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "pnpm run db:seed && pnpm run build && node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "migrate": "node scripts/migrate.js up",
    "migrate:rollback": "node scripts/migrate.js down",
    "migrate:create": "node-pg-migrate create --config-file node-pg-migrate.config.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@prisma/client": "^6.4.1",
    "@ticket-flow/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "node-pg-migrate": "^8.0.4",
    "prisma": "^6.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
